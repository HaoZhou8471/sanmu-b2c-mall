{insert_scripts files='jquery.json.js'}
{insert_scripts files='common.js,user.js'}
<script type="text/javascript">
function user_login(back_history){

	var logform = $('form[name="formLogin"]');
	var uniqueNo = logform.find('#uniqueNo');
	var pin = logform.find('#pin');
  var strustNo = logform.find('#strustNo');  
	var captcha = logform.find('#authcode');
	var error = logform.find('.msg-wrap');
	var back_act = logform.find("input[name='back_act']").val();

	if(uniqueNo.val()==''){
		error.css({'visibility':'visible'});
		error.find('.msg-error-text').html('请输入账户名');
		uniqueNo.parents('.item').addClass('item-error');
		return false;
	}

	if(pin.val()==''){
		error.css({'visibility':'visible'});
		pin.parents('.item').addClass('item-error');
		error.find('.msg-error-text').html('请输入密码');
		return false;
	}
	
	if(captcha.val()==''){
		error.css({'visibility':'visible'});
		captcha.parents('.item-detail').addClass('item-error');
		error.find('.msg-error-text').html('请输入验证码');
		return false;
	}

	if(back_history){
		
  $.ajax({
					type:"POST",
					url:"https://www.hi-sm.com/user.php?act=act_sclogin",
					cache:false,
					dataType:'json',     //接受数据格式
					data:'uniqueNo=' + uniqueNo.val()+'&pin='+pin.val()+'&captcha='+captcha.val()+'&strustNo='+strustNo.val(),
					success:return_login_back
				});        
	}else{
		
  $.ajax({
					type:"POST",
					url:"http://www.hi-sm.com/user.php?act=act_sclogin",
					cache:false,
					dataType:'json',     //接受数据格式
					data:'uniqueNo=' + uniqueNo.val()+'&pin='+pin.val()+'&captcha='+captcha.val()+'&strustNo='+strustNo.val(),
					success:return_login
				});          
	}
return false;
}
</script>
</head>
<body onclick="ecshop68_onclick();">
<script>
function erweima1(obj, sType) { var oDiv = document.getElementById(obj); if (sType == 'show') { oDiv.style.display = 'block';} if (sType == 'hide') { oDiv.style.display = 'none';} }
</script>
<div class="logo-r">
  <div class="logo-info-r"><a href="./" class="logo"></a><span class="findpw">登录平台</span><!-- #BeginLibraryItem "/library/user_right.lbi" --><!-- #EndLibraryItem --></div>
</div>
<div class="w"> 
  <!--#登录界面 start--> 
  <!-- {if $action eq 'login'} -->
  <div class="login-wrap" id="entry">
  	<div class="login-banner">
    	<div class="w990 position-relative">
        	<!-- #BeginLibraryItem "/library/login_banner.lbi" --><!-- #EndLibraryItem -->
            <div class="login-form">
            <form name="formLogin" action="user.php?XDEBUG_SESSION_START=ECLIPSE_DBGP" method="post" onSubmit="return user_login(1)">
              <div class="login-tit">个人/企业登录<a class="regist-link main-color" href="register.php">立即注册 <i>&gt;</i></a></div>
              
              <div class="form">
                <div class="msg-wrap">
                    <div class="msg-error">
                        <i class="msg-icon"></i><span id="msg-error-text" class="msg-error-text"></span>
                    </div>
                </div>

			    <div class="item item-name">
                	<i class="icon"></i>
                  	<input type="text" id="uniqueNo" name="uniqueNo" class="text" tabindex="1" placeholder="uniqueNo"/>
                </div>
                <div class="item item-name">
                	<i class="icon"></i>
                	<input type="text" id="pin" name="pin" class="text" tabindex="2" placeholder="pin"/>
                </div>
                 <div class="item item-name">
                  <i class="icon"></i>
                  <input type="text" id="strustNo" name="strustNo" class="text" tabindex="2" placeholder="strustNo"/>
                </div>               
                <!-- 判断是否启用验证码{if $enabled_captcha} -->
                <div class="item item-authcode clearfix" id="o-authcode">
                	<div class="item-detail fl">
                    	<i class="icon"></i>
                        <input type="text" id="authcode" name="captcha" class="text text-1" tabindex="3"/>
                    </div>
                    <label class="img fl"> <img src="captcha.php?is_login=1&{$rand}" alt="captcha" style="vertical-align: middle;cursor: pointer;" onClick="this.src='captcha.php?is_login=1&'+Math.random()" /> </label>
                </div>
                <!--{/if}-->
                <div class="safety" id="autoentry">
                    <label for="remember" class="mar-b"><input type="checkbox" value="1" name="remember" id="remember" class="checkbox"/>{$lang.remember}</label>
                    
                </div>
                <div class="login-btn">
                  <input type="hidden" name="act" value="act_login" />
                  <input type="hidden" name="back_act" value="{$back_act}" />
                  <input type="submit" name="submit" class="btn-img btn-entry" id="loginsubmit" value="立即登录" />
                </div>
                
            </form>
        </div>
        </div>
    </div>
  </div>
  <!--{/if}--> 
  <!--#登录界面 end--> 


</div>
<div class="site-footer">
    <div class="footer-related">
  		<!-- #BeginLibraryItem "/library/page_footer.lbi" --><!-- #EndLibraryItem -->
  </div>
</div>
</body>
